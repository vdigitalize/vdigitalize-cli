  "repository": {
    "type": "git",
    "url": "git+https://github.com/vdigitalize/vdigitalize-cli.git"
  },
  "homepage": "https://github.com/vdigitalize/vdigitalize-cli#readme",
  "bugs": {
    "url": "https://github.com/vdigitalize/vdigitalize-cli/issues"
  },
